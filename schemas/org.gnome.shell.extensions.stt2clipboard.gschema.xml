<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.stt2clipboard" path="/org/gnome/shell/extensions/stt2clipboard/">
    <key name="shortcut-key" type="as">
      <default><![CDATA[['F9']]]></default>
      <summary>Toggle shortcut</summary>
      <description>Shortcut to start/stop speech to text</description>
    </key>
    <key name="save-path" type="s">
      <default>'stt_record.wav'</default>
      <summary>Record save path</summary>
      <description>Path where the record will be saved (relative to home or absolute)</description>
    </key>
  </schema>
</schemalist>
